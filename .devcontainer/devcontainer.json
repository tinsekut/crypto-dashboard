{
  "name": "YouTube Trend Generator",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "youtube_trend_generator.py",
        ".env.example"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt && [ ! -f .env ] && cp .env.example .env || true && echo '✅ Dependencies installed. Edit .env with your API keys, then the app will launch automatically.'",
  "postAttachCommand": {
    "server": "streamlit run youtube_trend_generator.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "YouTube Trend Generator",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}