# ──────────────────────────────────────────────────────────────────────────────
# YouTube Trend Generator — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your keys below
# 3. The app reads these automatically on startup — no manual typing needed
# ──────────────────────────────────────────────────────────────────────────────

# YouTube Data API v3 key
# Get one free at: https://console.cloud.google.com
#   -> APIs & Services -> Library -> YouTube Data API v3 -> Enable
#   -> Credentials -> Create Credentials -> API Key
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# Your YouTube Channel ID  (starts with UC...)
# Find it: YouTube Studio -> Customization -> Basic info -> Channel URL
YOUTUBE_CHANNEL_ID=UCWfrG2O8YiS9hYPxm2xL5RA

# ── FREE AI providers (no billing, no credits required) ─────────────────────
# These run first in auto mode — the pipeline works at $0 when any key below is set.

# Cerebras Cloud — FREE: 1,000,000 tokens/day. Llama 3.3 70B on custom silicon.
# Fastest inference available. Get key at: https://inference.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
# Other available Cerebras models (run GET api.cerebras.ai/v1/models to see your account's list):
#   qwen-3-235b-a22b-instruct-2507  (Qwen 3 235B — highest quality)
#   gpt-oss-120b                    (OpenAI OSS 120B — best JSON reliability)
#   llama3.1-8b                     (fastest, lowest quality)

# Groq — FREE: 14,400 requests/day (8B) or 1,000/day (70B). Ultra-low latency.
# Get key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# SambaNova Cloud — FREE persistent tier: Llama 70B at 30 RPM; access to 405B.
# Get key at: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# Google Gemini — FREE: 1,000 requests/day on Flash-Lite; multimodal capable.
# Get key at: https://aistudio.google.com/app/apikey (no credit card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Hugging Face — FREE tier for LLM + FLUX image generation with one token.
# Get token at: https://huggingface.co/settings/tokens (needs "Inference" permission)
HF_TOKEN=

# ── Paid AI providers (optional — higher quality / longer context) ───────────
# Anthropic Claude API key (OPTIONAL — enables AI script generation)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI API key (OPTIONAL — preferred when AI_PROVIDER=auto and this is set)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AI provider: auto | cerebras | groq | sambanova | gemini | hf | openai | anthropic
# auto = free providers first (cerebras→groq→sambanova→gemini→hf), then paid.
# Set to a specific value to force one provider.
AI_PROVIDER=auto
# Best quality default for script/content/production planning.
# Use gpt-5.4 for lower cost with strong quality, or gpt-5.4-mini for cheap/fast runs.
OPENAI_MODEL=gpt-5.5
OPENAI_API_MODE=responses
OPENAI_REASONING_EFFORT=high
OPENAI_VERBOSITY=high
OPENAI_MAX_OUTPUT_TOKENS=80000
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Defaults (change if needed) ────────────────────────────────────────────
# Region code for trending lookup (US, GB, CA, AU, IN, PH, SG, ...)
DEFAULT_REGION=US

# Category (All, Gaming, Education, Music, Science & Technology, ...)
DEFAULT_CATEGORY=All

# Number of trending videos to pull per fetch (10-50)
MAX_RESULTS=25

# ── Background image sources ────────────────────────────────────────────────

# Pexels API key — enables real stock photo + video backgrounds (HIGHLY recommended)
# Free at: https://www.pexels.com/api/
# Used for: photo search (per_page=80, 15 pages), video frame extraction
# Dual URL+hash dedup ensures no image ever repeats across any video.
PEXELS_API_KEY=your_pexels_api_key_here

# Unsplash API — free 50 req/hr; real photography distinct from Pexels aesthetic
# Register app at: https://unsplash.com/developers (Access Key, not Secret)
# Note: must credit photographer per Unsplash TOS (watermark added automatically)
UNSPLASH_ACCESS_KEY=

# Pollinations.ai — completely FREE FLUX-based AI image generation, no key required
# Set key for higher rate limits at: https://enter.pollinations.ai (optional)
# Falls back to keyless public endpoint if blank — still works without a key
POLLINATIONS_KEY=

# Stability AI API key — cheaper AI image generation fallback (~$0.003/image)
# Get one at: https://platform.stability.ai/account/keys
# Set STABILITY_BG=1 to activate (opt-in to control spend).
STABILITY_API_KEY=
STABILITY_BG=

# DALL-E 3 background generation — highest quality (~$0.08/image HD)
# Uses your existing OPENAI_API_KEY above.
# Set DALLE_BG=1 to activate (opt-in to control spend).
# Fallback order: Pexels photo → Pexels video frame → Stability AI → Replicate → DALL-E 3 → gradient
DALLE_BG=

# Replicate.com AI image generation — mid-tier quality/cost (~$0.003-0.008/image)
# Uses Flux Dev model by default. Sits between Stability AI and DALL-E 3 in the waterfall.
# Get API key at: https://replicate.com/account/api-tokens
# Set REPLICATE_BG=1 to activate (opt-in to control spend).
REPLICATE_API_KEY=your_replicate_api_key_here
REPLICATE_BG=

# ── TTS / Voice ──────────────────────────────────────────────────────────────

# Primary TTS voice — Microsoft neural voices via edge-tts (free, high quality)
# Options: en-US-JennyNeural (female), en-US-GuyNeural (male),
#          en-US-AriaNeural (female, warm), en-GB-RyanNeural (UK male)
TTS_VOICE=en-US-GuyNeural

# OpenAI TTS voice — used when OPENAI_API_KEY is set (studio quality, costs ~$0.015/1k chars)
# Options: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=

# Multi-voice TTS — rotate voices across sections for freshness (edge-tts voices)
# Format: comma-separated list. Leave blank to use TTS_VOICE for all sections.
# Example: en-US-GuyNeural,en-US-AriaNeural,en-GB-RyanNeural
SECTION_VOICES=

# ── Upload & Schedule ────────────────────────────────────────────────────────

# Upload privacy: private | unlisted | public
YOUTUBE_PRIVACY=public

# Schedule hour (UTC) when using --schedule mode (0-23)
SCHEDULE_HOUR=9

# ── Audio / Music ────────────────────────────────────────────────────────────

# Optional: path to a local royalty-free MP3 for background music
# The track is looped/trimmed automatically and mixed at 7% volume under narration
# Leave blank to disable background music
BACKGROUND_MUSIC_PATH=

# ── Video renderer ───────────────────────────────────────────────────────────

# moviepy = current Python renderer (default, no extra deps)
# remotion = next-gen React/Remotion renderer (requires: cd remotion && npm install)
# auto     = try Remotion, fall back to MoviePy
VIDEO_RENDERER=auto

# ── Quality gate ─────────────────────────────────────────────────────────────

# block = stop upload if the video fails monetization/readiness checks
# warn  = save report and upload anyway
# off   = skip quality checks
QUALITY_GATE_MODE=block

# Long-form pass score (0-100). Shorts threshold = max(55, THRESHOLD - 20).
QUALITY_GATE_THRESHOLD=88

# Max AI rewrite loops before giving up on a low-scoring script
SCRIPT_REWRITE_PASSES=3

# ── AI credit information ───────────────────────────────────────────────────

# on = show known/unknown paid-provider credit info before generation
# off = skip paid-provider credit info
AI_CREDIT_INFO=on

# OpenAI and Anthropic do not expose a simple remaining-credit endpoint for
# normal API keys. Put your Console/Billing remaining amount here if you want
# it printed in check.py / pipeline logs. This is informational only.
OPENAI_CREDIT_BALANCE_USD=
ANTHROPIC_CREDIT_BALANCE_USD=

# Replicate balance is manual from its billing page.
REPLICATE_CREDIT_BALANCE_USD=

# ── Remotion visual style (advanced) ─────────────────────────────────────────

# Hex seed for director package selection (leave blank for random per render)
VIDEO_STYLE_SEED=

# Force a specific director package (leave blank for auto-selection by topic)
# Options: documentary_investigation | kinetic_shorts_energy | cinematic_human_story
#          myth_buster_lab | social_feed_takeover | premium_editorial
VIDEO_DIRECTOR_PACKAGE=

# ── React Three Fiber 3D scenes ──────────────────────────────────────────────
# USE_3D_SCENES=1 enables React Three Fiber 3D environments in the Remotion renderer.
# Requires VIDEO_RENDERER=remotion or VIDEO_RENDERER=auto.
# 3D scenes replace static Pexels backgrounds with GPU-rendered WebGL environments.
USE_3D_SCENES=0

# ── Cinematic 3D engine (cinematic_engine.py) ────────────────────────────────
# Replaces flat Ken Burns with hyper-realistic 2.5D parallax + depth-of-field
# + god rays + film grain + chromatic aberration + Zach King warp cuts.
#
# Effects enabled:
#   • 2.5D parallax — 3 depth layers move at different speeds (near/mid/far)
#   • Depth of field — background blurs based on heuristic depth map
#   • God rays — volumetric light shafts from bright sky/window regions
#   • Film grain — realistic cinematic texture on every frame
#   • Chromatic aberration — RGB channel split for lens realism
#   • Zach King warp cuts — zoom_punch → ripple → push_warp between cuts
#   • 9 camera moves matched to scene_style (push-in, orbit, handheld, pull-out…)
#   • 6 cinematic color grades matched to color_mood
#
# Performance: ~8–9× realtime on a modern laptop (vs ~3× for Ken Burns).
# A 10-minute video renders in ~90 min instead of ~30 min with engine on.
# Shorts (55s) render in ~8 min instead of ~3 min.
#
# 0 = Ken Burns only (fast)
# 1 = Full cinematic engine (movie quality)
CINEMATIC_ENGINE=1
